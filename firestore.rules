rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return request.auth.token.email;
    }

    function isConversationParticipant(emails) {
      return isSignedIn() && authEmail() in emails;
    }

    // Public registration lookup by email doc id + new sign-ups
    match /registrations/{email} {
      allow read: if true;
      allow create: if request.resource.data.email.lower() == email;
      allow update, delete: if false;
    }

    // Resource library (explore page)
    match /media/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Visit counter (best-effort analytics)
    match /analytics/visits {
      allow read: if true;
      allow write: if true;
    }

    match /analytics/{docId} {
      allow read: if false;
      allow write: if true;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /creators/{email} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /conversations/{conversationId} {
      allow read: if isConversationParticipant(resource.data.participantEmails);
      allow create: if isConversationParticipant(request.resource.data.participantEmails)
        && request.resource.data.participantEmails.size() == 2;
      allow update: if isConversationParticipant(resource.data.participantEmails);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConversationParticipant(
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantEmails
        );
        allow create: if isConversationParticipant(
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantEmails
        ) && request.resource.data.senderEmail == authEmail();
        allow update, delete: if false;
      }
    }
  }
}
